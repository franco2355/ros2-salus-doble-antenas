					}
				]
			},
			{
				"name": "C++ compilar y debuggear",
				"type": "cppdbg",
				"request": "launch",
				"preLaunchTask": "compilar",
				"program": "${workspaceFolder}/main",
				"args": [],
				"stopAtEntry": false,
